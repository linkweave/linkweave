{
  "name": "@linkweave/cli",
  "version": "0.1.0",
  "description": "Manage LinkWeave bookmarks from the command line",
  "keywords": [
    "bookmarks",
    "bookmark-manager",
    "linkweave",
    "cli"
  ],
  "homepage": "https://linkweave.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linkweave/linkweave.git",
    "directory": "cli"
  },
  "license": "BUSL-1.1",
  "type": "module",
  "bin": {
    "linkweave": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/main.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm run type-check && pnpm run test",
    "prepublishOnly": "pnpm run check && pnpm run build"
  },
  "dependencies": {
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
