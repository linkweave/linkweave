{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // DOM lib is required by the generated typescript-fetch client
    // (Response, RequestCredentials, ...); at runtime Node 24 provides them.
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "tsup.config.ts",
    "vitest.config.ts",
    "../frontend/src/api/generated/**/*.ts"
  ]
}
