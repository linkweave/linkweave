{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chainlink",
  "version": "0.1.0",
  "identifier": "com.markushofstetter.chainlink",
  "build": {
    "frontendDist": "../splash"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Chainlink",
        "width": 1280,
        "height": 832,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bin/quarkus-app": "quarkus-app",
      "bin/web": "web",
      "bin/runtime": "runtime"
    }
  }
}
