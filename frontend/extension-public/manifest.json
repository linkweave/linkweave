{
  "manifest_version": 3,
  "name": "Chainlink",
  "version": "0.0.0",
  "description": "Save and browse your Chainlink bookmarks",
  "permissions": ["activeTab", "tabs", "contextMenus", "storage"],
  "host_permissions": [
    "https://chainlink.markushofstetter.com/*",
    "https://dev-chainlink.markushofstetter.com/*"
  ],
  "icons": {
    "48": "icon-48.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chainlink",
    "default_icon": {
      "48": "icon-48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "service-worker.js",
    "scripts": ["service-worker.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "chainlink@markushofstetter.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["browsingActivity"]
      }
    }
  }
}
