{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint:css": "stylelint \"src/**/*.css\" --fix",
    "analyze": "fallow --skip health --baseline .fallow-baseline.json",
    "analyze:deadcode": "fallow dead-code --baseline .fallow-baseline.json",
    "analyze:health": "fallow health",
    "format": "prettier --write --experimental-cli src/",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "coverage:e2e": "E2E_COVERAGE=1 playwright test --project=chromium",
    "coverage:e2e:report": "nyc report",
    "coverage:unit": "vitest run --coverage",
    "coverage:combine": "node scripts/coverage-combine.mjs",
    "generate-api": "tsx scripts/generate-api.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:extension": "vite build --watch --config vite.config.extension.ts --mode extension.development",
    "build:extension": "vite build --config vite.config.extension.ts --mode extension.production",
    "package:extension": "pnpm run build:extension && web-ext build --source-dir dist-extension --artifacts-dir . --overwrite-dest --filename=\"linkweave-ext-$(date +%Y%m%d-%H%M%S).zip\""
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@sentry/vue": "^10.54.0",
    "@vee-validate/zod": "^4.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-color": "^3.3.3",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.32.0",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/chrome": "^0.0.287",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.51.0",
    "eslint-plugin-vue": "~10.8.0",
    "fake-indexeddb": "^6.2.5",
    "fallow": "2.89.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "nyc": "^18.0.0",
    "oxlint": "~1.51.0",
    "prettier": "3.8.1",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-istanbul": "^9.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.2.5",
    "web-ext": "^10.1.0"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
