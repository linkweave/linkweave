---
const features = [
  {
    icon: 'folders',
    title: 'Nested Folder Hierarchy',
    description:
      'Organize bookmarks into deeply nested folders with drag-and-drop reorganization. Breadcrumbs keep you oriented. A structure most bookmark managers simply don\'t offer.',
  },
  {
    icon: 'tags',
    title: 'Tags with Color Coding',
    description:
      'Label bookmarks with custom, color-coded tags. Filter by multiple tags simultaneously. Tags combine with folder and search filters using AND logic for precise results.',
  },
  {
    icon: 'collections',
    title: 'Collections & Sharing',
    description:
      'Group bookmarks into separate collections for work, personal, or team use. Share collections with other users and control access with role-based permissions.',
  },
  {
    icon: 'search',
    title: 'Powerful Search Operators',
    description:
      'Type structured queries like #vue, folder:recipes, created:>2026-01, or -#deprecated. Autocomplete suggests operators, tags, and folders as you type. Negation and date ranges supported.',
  },
  {
    icon: 'smart',
    title: 'Saved Searches & Smart Collections',
    description:
      'Save any search query as a virtual folder in your sidebar. Smart collections always reflect live data — they re-evaluate on every view, never storing a stale snapshot.',
  },
  {
    icon: 'properties',
    title: 'Typed Bookmark Properties',
    description:
      'Attach structured metadata — priority, reading status, due dates — using typed key-value properties (text, number, date, select, multi-select, boolean). Filter by property values.',
  },
  {
    icon: 'ai',
    title: 'AI Tag Suggestions',
    description:
      'An optional LLM suggests tags drawn only from your collection\'s existing vocabulary — it can never invent a tag you haven\'t used. The default Ollama provider runs fully local with zero data egress. A pluggable provider supports hosted OpenAI-compatible APIs if you prefer.',
  },
  {
    icon: 'offline',
    title: 'Full Offline Mode',
    description:
      'Browse, search, and filter your bookmarks with zero network. Collection data is cached in IndexedDB, scoped per-user. The app shell loads from a service worker in under 500 ms.',
  },
  {
    icon: 'trash',
    title: 'Trashbin & Cleanup Suggestions',
    description:
      'Deleted items go to a recoverable trashbin, not a black hole. Review bookmarks you haven\'t used in a while and declutter in bulk — dismiss suggestions you want to keep.',
  },
  {
    icon: 'screenshots',
    title: 'Screenshot Previews',
    description:
      'Enable a tiles layout that displays bookmarks as visual cards with screenshot cover images, captured asynchronously by an isolated Playwright sidecar service.',
  },
  {
    icon: 'import',
    title: 'Import with Review',
    description:
      'Import bookmarks from Brave or Firefox. Review the parsed tree in a two-phase flow — deselect folders, individual bookmarks, and duplicates before anything is written.',
  },
  {
    icon: 'extension',
    title: 'Browser Extension & API',
    description:
      'A Chrome/Firefox extension saves the current page in one click. Personal API keys enable CLI and script automation. Full REST API with OpenAPI spec.',
  },
];

const icons: Record<string, string> = {
  folders: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>`,
  tags: `<path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>`,
  collections: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>`,
  search: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>`,
  smart: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  properties: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`,
  ai: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
  offline: `<path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-12.728 12.728m0 0L3 21m2.636-2.636A9 9 0 1119.728 6.272M9 9h.01M15 9h.01M9 15a3 3 0 016 0"/>`,
  trash: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>`,
  screenshots: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
  import: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>`,
  extension: `<path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>`,
};
---

<section id="features" class="py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Organize the way you actually think
      </h2>
      <p class="mt-4 text-lg text-[var(--color-muted-foreground)]">
        Nested folders, typed properties, a search operator language, local AI
        tagging, offline mode, and more &mdash; everything you'd expect from a
        serious bookmark manager, none of it behind a paywall.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature, i) => (
          <div
            class="fade-in group rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] p-6 transition-all hover:shadow-lg hover:border-[var(--color-primary)]/30"
            style={`transition-delay: ${i * 50}ms`}
          >
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)] transition-colors group-hover:bg-[var(--color-primary)] group-hover:text-white">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icons[feature.icon]} />
            </div>
            <h3 class="text-lg font-semibold">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted-foreground)]">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
