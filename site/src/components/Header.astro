---
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-background)]/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo-mark.png" alt="LinkWeave" class="h-8 w-8" />
      <span class="text-lg font-bold tracking-tight">LinkWeave</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a href="#features" class="text-sm font-medium text-[var(--color-muted-foreground)] transition-colors hover:text-[var(--color-foreground)]">Features</a>
      <a href="#differentiators" class="text-sm font-medium text-[var(--color-muted-foreground)] transition-colors hover:text-[var(--color-foreground)]">Why LinkWeave</a>
      <a href="#self-hosting" class="text-sm font-medium text-[var(--color-muted-foreground)] transition-colors hover:text-[var(--color-foreground)]">Self-Hosting</a>
      <a href="#comparison" class="text-sm font-medium text-[var(--color-muted-foreground)] transition-colors hover:text-[var(--color-foreground)]">Comparison</a>
    </div>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/linkweave/linkweave"
        target="_blank"
        rel="noopener"
        class="hidden text-sm font-medium text-[var(--color-muted-foreground)] transition-colors hover:text-[var(--color-foreground)] sm:block"
      >
        GitHub
      </a>
      <a
        href="https://linkweave.dev/login"
        class="rounded-lg bg-[var(--color-primary)] px-4 py-2 text-sm font-semibold text-[var(--color-primary-foreground)] shadow-sm transition-all hover:shadow-md hover:brightness-110"
      >
        Launch App
      </a>
    </div>
  </nav>
</header>
