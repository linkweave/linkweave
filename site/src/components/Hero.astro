---
---

<section class="relative overflow-hidden pt-32 pb-20">
  <div class="dot-grid-fade absolute inset-0"></div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-6 font-mono text-sm tracking-wide text-[var(--color-muted-foreground)]">
        self-hosted &middot; source-available &middot; sqlite
      </p>

      <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
        Your links.<br />
        <span class="font-normal text-[var(--color-muted-foreground)]">Your server.</span><br />
        Your rules.
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--color-muted-foreground)]">
        LinkWeave is a bookmark manager with nested folders, tags, shared
        collections, AI tagging, and full offline mode.
        <a href="https://linkweave.dev/login" class="font-medium text-[var(--color-primary)] underline-offset-2 hover:underline">Try the hosted instance</a>
        or self-host with Docker &mdash; same features either way.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="https://linkweave.dev/login"
          class="w-full rounded-lg bg-[var(--color-primary)] px-6 py-3 text-center text-base font-semibold text-[var(--color-primary-foreground)] transition-all hover:brightness-110 sm:w-auto"
        >
          Get Started &rarr;
        </a>
        <a
          href="#features"
          class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] px-6 py-3 text-center text-base font-semibold text-[var(--color-foreground)] transition-all hover:bg-[var(--color-secondary)] sm:w-auto"
        >
          Explore Features
        </a>
      </div>
    </div>

    <!-- Hero screenshot -->
    <div class="fade-in mx-auto mt-16 max-w-5xl">
      <div class="screenshot-frame">
        <img
          src="/screenshots/main-grid.png"
          alt="LinkWeave bookmark manager main view showing folders, tags, and bookmark cards"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
