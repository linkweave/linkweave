@startuml Chainlink Use Cases
left to right direction

skinparam usecaseBackgroundColor<<implemented>> #E8F5E9
skinparam usecaseBorderColor<<implemented>> #4CAF50

actor "User" as user
actor "Collection Owner" as owner

owner --|> user

rectangle "Chainlink Bookmark Manager" {

    rectangle "Collection Management" {
        usecase "UC-001\nAuto-Provision on\nFirst Login" as UC001 <<implemented>>
        usecase "UC-002\nAuto-Navigate\nto Collection" as UC002 <<implemented>>
        usecase "UC-003\nList Collections" as UC003 <<implemented>>
        usecase "UC-004\nSet Default Collection" as UC004
        usecase "UC-023\nShare Collection" as UC023
        usecase "UC-024\nAccess Shared Collection" as UC024
        usecase "UC-025\nRevoke Collection\nAccess" as UC025
    }

    rectangle "Bookmark Management" {
        usecase "UC-005\nCreate Bookmark" as UC005 <<implemented>>
        usecase "UC-006\nView Bookmarks" as UC006 <<implemented>>
        usecase "UC-007\nEdit Bookmark" as UC007 <<implemented>>
        usecase "UC-008\nDelete Bookmark" as UC008 <<implemented>>
        usecase "UC-013\nMove Bookmark\nto Folder" as UC013 <<implemented>>
    }

    rectangle "Folder Management" {
        usecase "UC-009\nCreate Folder" as UC009
        usecase "UC-010\nView Folders" as UC010
        usecase "UC-011\nRename Folder" as UC011
        usecase "UC-012\nNest Folders" as UC012
        usecase "UC-014\nDelete Folder" as UC014
    }

    rectangle "Tag Management" {
        usecase "UC-015\nCreate Tag" as UC015 <<implemented>>
        usecase "UC-016\nView Tags" as UC016 <<implemented>>
        usecase "UC-017\nEdit Tag" as UC017 <<implemented>>
        usecase "UC-018\nDelete Tag" as UC018 <<implemented>>
        usecase "UC-019\nApply Tag\nto Bookmark" as UC019 <<implemented>>
        usecase "UC-020\nRemove Tag\nfrom Bookmark" as UC020 <<implemented>>
    }

    rectangle "Search & Filtering" {
        usecase "UC-021\nFilter Bookmarks\nby Tag" as UC021 <<implemented>>
        usecase "UC-022\nFilter Bookmarks\nby Folder" as UC022
        usecase "UC-032\nSearch Bookmarks" as UC032 <<implemented>>
    }

    rectangle "Navigation" {
        usecase "UC-029\nNavigate Folder\nHierarchy" as UC029
    }

    rectangle "Import" {
        usecase "UC-031\nImport Browser\nBookmarks" as UC031 <<implemented>>
        note right of UC031
          See bookmark-import.md
          for implementation plan
        end note
    }
}

' Collection Management
user --> UC001
user --> UC002
user --> UC003
user --> UC004
owner --> UC023
user --> UC024
owner --> UC025

' Bookmark Management
user --> UC005
user --> UC006
user --> UC007
user --> UC008
user --> UC013

' Folder Management
user --> UC009
user --> UC010
user --> UC011
user --> UC012
user --> UC014

' Tag Management
user --> UC015
user --> UC016
user --> UC017
user --> UC018
user --> UC019
user --> UC020

' Filtering
user --> UC021
user --> UC022
user --> UC032

' Navigation
user --> UC029

' Import
user --> UC031

legend right
  |<#E8F5E9>| Implemented |
  |<#FFFFFF>| Not started |
endlegend

@enduml
